# Supabase (reuse the existing Lovable Cloud project — anon key only, no
# service role key needed; nothing in this app requires elevated DB access)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Public origin this app is served from — used to build Sumit redirect/IPN URLs.
# Set to the Railway domain (or custom domain) in production.
PUBLIC_SITE_URL=https://ibda-webinar.up.railway.app

# Resend — contact sync (no Audience needed, that's the deprecated Resend
# model) + confirmation/payment-status emails
RESEND_API_KEY=
RESEND_FROM_EMAIL="IBDA Webinars <webinar@ibda-law.com>"

# Sumit — payment gateway (replaces Takbull)
SUMIT_API_KEY=
SUMIT_COMPANY_ID=
SUMIT_WEBHOOK_KEY=
SUMIT_BASE_URL=https://api.sumit.co.il
