# Supabase (order-tracking table only — reuse the existing Lovable Cloud project)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Public origin this app is served from — used to build Sumit redirect/IPN URLs.
# Set to the Railway domain (or custom domain) in production.
PUBLIC_SITE_URL=https://ibda-webinar.up.railway.app

# Resend — audience membership + confirmation/payment-status emails
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL="IBDA Webinars <webinar@ibda-law.com>"

# Sumit — payment gateway (replaces Takbull)
SUMIT_API_KEY=
SUMIT_COMPANY_ID=
SUMIT_WEBHOOK_KEY=
SUMIT_BASE_URL=https://api.sumit.co.il

# Google Sheets backup — service account with edit access on the target sheet
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_REGISTRATIONS_ID=
